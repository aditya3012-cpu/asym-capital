# ─── SMTP (Zoho Mail example — works with any SMTP provider) ───────────────
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_USER=contact@asymcapital.in
SMTP_PASS=your_password_here

# ─── Recipients ────────────────────────────────────────────────────────────
CONTACT_TO_EMAIL=contact@asymcapital.in

# ─── App ───────────────────────────────────────────────────────────────────
APP_ENV=development

# ─── CORS (comma-separated, no spaces) ─────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:8000,https://asymcapital.in
